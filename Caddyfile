# handle blocks are required to prevent file_server from intercepting /api/* requests.
# Without them, file_server handles POST requests to /api/* and returns 405 Method Not Allowed
# because file_server only accepts GET/HEAD. Explicit handle blocks guarantee /api/* is always
# proxied to the backend regardless of HTTP method.

time.branam.us {
	handle /api/* {
		reverse_proxy localhost:3000
	}
	handle {
		root * /home/ec2-user/track-web/client-tracker/dist
		try_files {path} /index.html
		file_server
	}
}

movies.branam.us {
	handle /api/* {
		reverse_proxy localhost:3000
	}
	handle {
		root * /home/ec2-user/track-web/client-movies/dist
		try_files {path} /index.html
		file_server
	}
}
