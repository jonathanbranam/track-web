{
  "name": "track-web",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client"],
  "scripts": {
    "build:client": "npm run build -w client",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node out/index.js",
    "dev": "concurrently \"tsx watch src/index.ts\" \"npm run dev -w client\"",
    "hash-password": "tsx scripts/hash-password.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.3",
    "better-sqlite3": "^11.7.0",
    "bcrypt": "^5.1.1",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.9",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
