# Your login email
EMAIL=you@example.com

# Bcrypt hash of your password — generate with: npm run hash-password
PASSWORD_HASH=$2b$12$...

# Random secret for signing session cookies — use: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# Port the Node server listens on
PORT=3000

# Path to SQLite database file
SQLITE_PATH=data.db
